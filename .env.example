# Copy to .env and fill in your Deribit TESTNET API key (test.deribit.com).
# .env is git-ignored — NEVER commit real keys. Sim mode needs none of these.
#
# Create a key at https://test.deribit.com  ->  Account  ->  API.
# Use a key WITHOUT withdrawal rights. The bot always targets the testnet.

DERIBIT_CLIENT_ID=your_testnet_client_id_here
DERIBIT_CLIENT_SECRET=your_testnet_client_secret_here

# Optional: override the run mode without editing the YAML ("sim" or "live").
# BOT_MODE=sim
